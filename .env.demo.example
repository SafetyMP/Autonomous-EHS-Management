# Copy to .env.local for a local Docker Postgres demo stack.
# 1) docker compose -f docker-compose.demo.yml up -d
# 2) cp .env.demo.example .env.local
# 3) npm ci && npm run db:migrate && npm run db:seed:demo
# 4) npm run dev

DATABASE_URL=postgresql://ehs:ehs@127.0.0.1:5433/ehs
DATABASE_USE_PG=1

# 32+ chars; replace in private environments
BETTER_AUTH_SECRET=local-demo-better-auth-secret-min-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo UX (never enable DEMO_MODE on production deployments)
DEMO_MODE=true
DEMO_ADMIN_EMAIL=demo.admin@example.com
DEMO_ADMIN_PASSWORD=demo-admin-password-change-me
NEXT_PUBLIC_DEMO_MODE=1

# Browse-only sandbox: uncomment to block all tRPC mutations while DEMO_MODE=true
# DEMO_READ_ONLY=true

# Optional: Upstash (omit for local demo — rate limiting becomes in-memory no-op when unset)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: AI narrative enrichment during demo seed
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Assistant / structured intake use the same gateway when keys are set (see README AI section).
#
# Optional: set to 0 to skip synthetic cron_job_run backfill (global table — use on shared staging).
# DEMO_SEED_CRON_RUNS=0

# Optional: Enterprise OIDC (Better Auth Generic OAuth). Also set NEXT_PUBLIC_ENTERPRISE_SSO=1 and matching NEXT_PUBLIC_OIDC_PROVIDER_ID.
# OIDC_DISCOVERY_URL=https://your-idp.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_PROVIDER_ID=enterprise-oidc
# NEXT_PUBLIC_ENTERPRISE_SSO=1
# NEXT_PUBLIC_OIDC_PROVIDER_ID=enterprise-oidc

# Optional: Vercel Cron + integration webhook (set in staging/prod as needed)
# CRON_SECRET=
# INTEGRATION_INBOUND_SECRET=min-16-chars-shared-secret-for-post-api-integration-inbound
