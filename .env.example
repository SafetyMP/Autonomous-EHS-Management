# Neon or any Postgres connection string
DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# Driver / local Docker Postgres:
# - Hosted Neon (serverless): omit DATABASE_USE_PG (default) per README "Non-demo development".
# - Local docker-compose demo publishes Postgres on host port **5433** (avoids clashing with 5432).
#   Set DATABASE_USE_PG=1 and point DATABASE_URL at 127.0.0.1:5433 — see README "Turnkey local demo"
#   and `.env.demo.example`.
# DATABASE_USE_PG=1
# DATABASE_URL="postgresql://USER:PASS@127.0.0.1:5433/DATABASE"

# openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-chars-secret-key-here"

# Local dev
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: IndexedDB outbox when offline incident/observation submit (set NEXT_PUBLIC_FIELD_OUTBOX=1)
# NEXT_PUBLIC_FIELD_OUTBOX=1

# Optional: future on-device / VPC SLM hook for intake assist (see src/lib/ai/localIntakeSlm.ts)
# NEXT_PUBLIC_LOCAL_INTAKE_SLM=1

# Optional: POST /api/integration/inbound — Bearer secret; training_completion + hris_membership_sync payloads
# INTEGRATION_INBOUND_SECRET=

# Optional: Context Sync REST — cap org reads per UTC day (Upstash INCR) and max provenance rows returned per request
# CONTEXT_SYNC_ORG_DAILY_READ_LIMIT=10000
# CONTEXT_SYNC_PROVENANCE_MAX_LIMIT=200

# Optional: rate limiting (Phase 5)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Emergency only — bypass the prod fail-closed rate-limit gate without Upstash.
# Removes brute-force / cost-runaway protection on auth, tRPC, RAG ingest, and
# Context Sync REST. Unset as soon as UPSTASH_REDIS_REST_* are wired.
# RATE_LIMIT_DISABLED=true

# After first signup, link user to org (see README)
# SEED_ADMIN_EMAIL=you@company.com

# Optional: OpenAI or OpenAI-compatible API (enables `register()` in `src/instrumentation.ts`)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Playwright signed-in checks (see tests/e2e/auth/)
# PLAYWRIGHT_E2E_EMAIL=
# PLAYWRIGHT_E2E_PASSWORD=
# Optional: Calm Focus density/visual desk_contributor (defaults after db:seed:ci)
# PLAYWRIGHT_E2E_CONTRIBUTOR_EMAIL=e2e.contributor@ci.local
# PLAYWRIGHT_E2E_CONTRIBUTOR_PASSWORD=

# Scheduled cron + metrics scrape: Authorization: Bearer <same value>
# Routes: GET /api/cron/reminders, GET /api/cron/data-retention, GET /api/cron/metrics (metrics is pull/scrape — not invoked by platform cron).
# CRON_SECRET=

# CI / analysis only
# SKIP_ENV_VALIDATION=1

# Optional: durable background jobs (pg-boss). Requires a long-lived worker (`npm run job:worker`), not Vercel-only.
# PG_BOSS_ENABLED=true
# PG_BOSS_SCHEMA=pgboss

# Optional: dev-only enqueue logging without pg-boss (see docs/JOB_QUEUE.md)
# JOB_QUEUE_ENABLED=true
