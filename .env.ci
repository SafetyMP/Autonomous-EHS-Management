# Synthetic values for CI / Playwright only (no real secrets). Do not use in production.
# Loaded into GitHub Actions jobs and optionally by Vitest / Playwright via .env.ci.
# Use node-postgres in CI and local smoke when targeting Docker/GitHub Postgres (not Neon serverless).
DATABASE_URL=postgresql://ci:ci@127.0.0.1:5432/ehs_ci
DATABASE_USE_PG=1
BETTER_AUTH_SECRET=ci-local-fixture-secret-32chars-min!!
BETTER_AUTH_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
